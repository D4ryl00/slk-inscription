# ─── HelloAsso ───────────────────────────────────────────────────────────────
# Identifiants API générés dans l'espace admin de l'association
# (Paramètres → Développeur / API). NE JAMAIS committer les vraies valeurs.
HELLOASSO_CLIENT_ID=
HELLOASSO_CLIENT_SECRET=
# Slug de l'organisation (dans l'URL HelloAsso: helloasso.com/associations/<slug>)
HELLOASSO_ORG_SLUG=association-stade-laurentin-karate
# "sandbox" pour les tests, "prod" en production
HELLOASSO_ENV=sandbox

# ─── Google Sheets (compte de service, API Sheets uniquement) ────────────────
# Coller le JSON de la clé du service account sur UNE seule ligne (échappé),
# ou l'encoder en base64 et préfixer par "base64:".
GOOGLE_SERVICE_ACCOUNT_JSON=
# ID du Google Sheet (partie entre /d/ et /edit dans l'URL)
GOOGLE_SHEET_ID=
# Nom de l'onglet où écrire les adhérents (par défaut la 1re feuille)
GOOGLE_SHEET_TAB=Feuille 1

# ─── Front ───────────────────────────────────────────────────────────────────
# URL publique du site (pour construire les returnUrl/backUrl/errorUrl du Checkout)
SITE_URL=http://localhost:8888
